{
  "name": "tinny-backend",
  "version": "1.0.2",
  "description": "A lightweight and flexible backend framework built on Node.js.",
  "license": "MIT",
  "author": {
    "name": "Yassine Ajagrou",
    "email": "yassineajagrou8@gmail.com",
    "url": "https://github.com/iaceene"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iaceene/tinny-backend.git"
  },
  "bugs": {
    "url": "https://github.com/iaceene/tinny-backend/issues"
  },
  "homepage": "https://github.com/iaceene/tinny-backend#readme",
  "keywords": [
    "backend",
    "framework",
    "router",
    "routing",
    "http",
    "node",
    "nodejs",
    "typescript",
    "server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}